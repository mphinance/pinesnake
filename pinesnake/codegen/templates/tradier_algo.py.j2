def place_order(symbol: str, side: str, qty: int, order_type: str = "market",
                price: float = None, stop: float = None) -> dict:
    """
    Place an order via Tradier API (or log in DRY_RUN mode).

    Args:
        symbol: Ticker symbol
        side: "buy" or "sell"
        qty: Number of shares
        order_type: "market", "limit", "stop", "stop_limit"
        price: Limit price (optional)
        stop: Stop price (optional)
    """
    if DRY_RUN:
        logger.info(f"🏜️  [DRY RUN] {side.upper()} {qty} shares of {symbol} "
                    f"({order_type}" +
                    (f", limit={price}" if price else "") +
                    (f", stop={stop}" if stop else "") + ")")
        return {"status": "dry_run", "side": side, "qty": qty}

    url = f"{BASE_URL}/accounts/{TRADIER_ACCOUNT}/orders"
    data = {
        "class": "equity",
        "symbol": symbol,
        "side": side,
        "quantity": str(qty),
        "type": order_type,
        "duration": "day",
    }
    if price and order_type in ("limit", "stop_limit"):
        data["price"] = str(price)
    if stop and order_type in ("stop", "stop_limit"):
        data["stop"] = str(stop)

    logger.info(f"🚀 Placing order: {side.upper()} {qty} {symbol} ({order_type})")
    resp = requests.post(url, headers=HEADERS, data=data)
    resp.raise_for_status()
    result = resp.json()
    logger.info(f"✅ Order placed: {result}")
    return result


def cancel_all_orders():
    """Cancel all open orders."""
    if DRY_RUN:
        logger.info("🏜️  [DRY RUN] Would cancel all open orders")
        return
    try:
        url = f"{BASE_URL}/accounts/{TRADIER_ACCOUNT}/orders"
        resp = requests.get(url, headers=HEADERS)
        resp.raise_for_status()
        orders = resp.json().get("orders", {}).get("order", [])
        if isinstance(orders, dict):
            orders = [orders]
        for order in orders:
            if order.get("status") in ("pending", "open", "partially_filled"):
                requests.delete(f"{url}/{order['id']}", headers=HEADERS)
                logger.info(f"Cancelled order {order['id']}")
    except Exception as e:
        logger.error(f"Cancel all orders failed: {e}")


