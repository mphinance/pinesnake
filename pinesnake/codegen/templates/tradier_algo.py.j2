# Interval mapping for Tradier API
INTERVAL_MAP = {
    "1min": "1min", "5min": "5min", "15min": "15min",
    "1h": "60min", "4h": "daily", "1d": "daily",
}


def fetch_bars(symbol: str, interval: str = "5min", count: int = 200) -> pd.DataFrame:
    """Fetch OHLCV bars from Tradier."""
    tradier_interval = INTERVAL_MAP.get(interval, interval)

    if tradier_interval in ("daily", "weekly", "monthly"):
        url = f"{BASE_URL}/markets/history"
        params = {"symbol": symbol, "interval": tradier_interval}
        resp = requests.get(url, headers=HEADERS, params=params)
        resp.raise_for_status()
        data = resp.json()
        bars = data.get("history", {}).get("day", [])
    else:
        url = f"{BASE_URL}/markets/timesales"
        params = {"symbol": symbol, "interval": tradier_interval, "session_filter": "open"}
        resp = requests.get(url, headers=HEADERS, params=params)
        resp.raise_for_status()
        data = resp.json()
        bars = data.get("series", {}).get("data", [])

    if not bars:
        logger.warning(f"No data returned for {symbol}")
        return pd.DataFrame()

    df = pd.DataFrame(bars)
    for col in ("open", "high", "low", "close", "price"):
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
    if "volume" in df.columns:
        df["volume"] = pd.to_numeric(df["volume"], errors="coerce").fillna(0).astype(int)
    if "price" in df.columns and "close" not in df.columns:
        df["close"] = df["price"]
    if "timestamp" in df.columns:
        df["timestamp"] = pd.to_datetime(df["timestamp"])
        df.set_index("timestamp", inplace=True)
    elif "date" in df.columns:
        df["date"] = pd.to_datetime(df["date"])
        df.set_index("date", inplace=True)

    return df.tail(count)


def is_market_open() -> bool:
    """Check if the US equity market is currently open."""
    try:
        resp = requests.get(f"{BASE_URL}/markets/clock", headers=HEADERS)
        resp.raise_for_status()
        return resp.json().get("clock", {}).get("state") == "open"
    except Exception as e:
        logger.error(f"Market clock check failed: {e}")
        return False


def get_position_qty(symbol: str) -> int:
    """Get current position quantity for a symbol."""
    try:
        url = f"{BASE_URL}/accounts/{TRADIER_ACCOUNT}/positions"
        resp = requests.get(url, headers=HEADERS)
        resp.raise_for_status()
        positions = resp.json().get("positions", {}).get("position", [])
        if isinstance(positions, dict):
            positions = [positions]
        for pos in positions:
            if pos.get("symbol", "").upper() == symbol.upper():
                return int(pos.get("quantity", 0))
    except Exception as e:
        logger.error(f"Position check failed: {e}")
    return 0


def calculate_qty(position_size: float, price: float) -> int:
    """Calculate number of shares based on position size and current price."""
    if price <= 0:
        return 0
    return max(1, int(position_size / price))


