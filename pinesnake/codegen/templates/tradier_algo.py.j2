def run_iteration():
    """Run one iteration of the strategy."""
    df = fetch_bars(SYMBOL, interval=TIMEFRAME)
    if df.empty:
        logger.warning("No data — skipping iteration")
        return

    df = calculate_indicators(df)
    signal = check_signals(df)

    if signal is None:
        logger.info(f"📊 No signal | {SYMBOL} close={df['close'].iloc[-1]:.2f}")
        return

    current_qty = get_position_qty(SYMBOL)
    current_price = float(df['close'].iloc[-1])

    if signal == "BUY" and current_qty == 0:
        qty = calculate_qty(POSITION_SIZE, current_price)
        place_order(SYMBOL, "buy", qty)
    elif signal == "SELL" and current_qty > 0:
        place_order(SYMBOL, "sell", current_qty)
    else:
        logger.info(f"📊 Signal={signal} but position={current_qty} — no action")


